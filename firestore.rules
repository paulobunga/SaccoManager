rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // HELPER FUNCTIONS FOR ROLE-BASED ACCESS
    // ==========================================

    // Check if user is authenticated with Firebase Auth
    function isAuthenticated() {
      return request.auth != null;
    }

    // Get the user's data from the users_registration collection.
    // Document ID can be 'user_username' or similar based on registration payload.
    function getUserData() {
      return get(/databases/$(database)/documents/users_registration/$(request.auth.uid)).data;
    }

    // Check if the authenticated user has ADMIN or SUPER_ADMIN privileges
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'ADMIN' ||
        request.auth.token.role == 'SUPER_ADMIN' ||
        getUserData().role == 'ADMIN' ||
        getUserData().role == 'SUPER_ADMIN'
      );
    }

    // Check if the authenticated user matches the owner ID or email of the document
    function isOwner(memberId) {
      return isAuthenticated() && (
        request.auth.uid == memberId || 
        request.auth.token.email == memberId
      );
    }

    // ==========================================
    // ROLE-BASED ACCESS RULES PER COLLECTION
    // ==========================================

    // 1. Users Registration Profiles
    match /users_registration/{docId} {
      // Users can view their own profile, Admins/Super Admins can view all profiles
      allow read: if isAuthenticated() && (
        docId == request.auth.uid || 
        docId == "user_" + request.auth.uid ||
        docId == "user_" + request.auth.token.email ||
        resource.data.id == request.auth.uid ||
        resource.data.email == request.auth.token.email ||
        isAdmin()
      );
      // Users can register or update their own profiles, Admins can write all
      allow write: if isAuthenticated() && (
        docId == request.auth.uid || 
        docId == "user_" + request.auth.uid ||
        docId == "user_" + request.auth.token.email ||
        request.resource.data.id == request.auth.uid ||
        request.resource.data.email == request.auth.token.email ||
        isAdmin()
      );
    }

    // 2. Savings Payments (Ledger Receipts)
    match /savings_payments/{docId} {
      // Members can only read/inspect their own payments
      allow read: if isAuthenticated() && (
        isOwner(resource.data.memberId) || 
        isAdmin()
      );
      // Members can submit their own payments (requires matching memberId)
      allow create: if isAuthenticated() && (
        isOwner(request.resource.data.memberId) || 
        isAdmin()
      );
      // Only authorized Admins can update/verify receipts or delete records
      allow update, delete: if isAdmin();
    }

    // 3. Loan Repayments
    match /loan_repayments/{docId} {
      // Members can inspect their own loan payments
      allow read: if isAuthenticated() && (
        isOwner(resource.data.memberId) || 
        isAdmin()
      );
      // Members can register their own loan installments
      allow create: if isAuthenticated() && (
        isOwner(request.resource.data.memberId) || 
        isAdmin()
      );
      // Only Admins can modify installment balances or remove transactions
      allow update, delete: if isAdmin();
    }

    // 4. Loan Applications
    match /loan_applications/{docId} {
      // Members can read if they are the borrower/applicant OR the assigned guarantor
      allow read: if isAuthenticated() && (
        isOwner(resource.data.memberId) || 
        isOwner(resource.data.guarantorId) || 
        isAdmin()
      );
      // Members can submit their own loan requests
      allow create: if isAuthenticated() && (
        isOwner(request.resource.data.memberId) || 
        isAdmin()
      );
      // Guarantors can update the application to sign off/approve the guarantee,
      // and Admins can approve/repay/disburse the loans.
      allow update: if isAuthenticated() && (
        (isOwner(resource.data.guarantorId) && request.resource.data.guarantorApproved != resource.data.guarantorApproved) ||
        isOwner(resource.data.memberId) ||
        isAdmin()
      );
      // Only Admins can purge loan application records
      allow delete: if isAdmin();
    }

    // 5. Miscellaneous/Audit Transactions & Temporary Buffers
    match /misc_transactions/{docId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.memberId) || 
        isOwner(docId) ||
        isAdmin()
      );
      allow write: if isAuthenticated() && (
        isOwner(request.resource.data.memberId) || 
        isAdmin()
      );
    }
  }
}
